# ============================================
# 🔴 必需配置（一定要改）
# ============================================

# 数据库配置
DB_NAME=ancient_architecture
DB_USER=postgres
DB_PASSWORD=your_secure_password_here  # ⚠️ 改成强密码！使用特殊字符
DB_PORT=5432

# CORS 跨域配置（前端地址）
# 开发: http://localhost
# 生产: https://yourdomain.com
CORS_ORIGIN=http://localhost

# AI 服务配置（DashScope）
# 从 https://dashscope.aliyun.com/ 获取你的 API Key
DASHSCOPE_API_KEY=sk-your_api_key_here  # ⚠️ 替换为实际 API Key

# ============================================
# 🟡 可选配置（按需调整）
# ============================================

# 后端服务配置
BACKEND_PORT=3000
NODE_ENV=production                    # 或 development

# 前端配置
WEB_PORT=80                            # 改为 8080 如果 80 被占用

# 数据源选择
DATA_SOURCE=json                       # 或 'postgres'

# 数据库连接池（性能调优）
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# 日志级别
LOG_LEVEL=info                         # 或 debug

# ============================================
# 🟢 无需修改（默认配置）
# ============================================

# 这些是容器内部使用的，不需要改
DB_CONTAINER_NAME=ancient-arch-postgres
BACKEND_CONTAINER_NAME=ancient-arch-backend
WEB_CONTAINER_NAME=ancient-arch-web
