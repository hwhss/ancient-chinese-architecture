# API 基础地址配置
# 开发环境建议使用本地地址，生产环境使用服务器地址
UNI_APP_API_BASE_URL=http://localhost:9527

# 远程服务器地址（用于快速切换）
# UNI_APP_REMOTE_SERVER_URL=http://your-server-ip

# 图片源模式: object | local | server
UNI_APP_IMAGE_SOURCE=local

# 测试环境预设地址
# UNI_APP_API_PRESET_TEST=http://test-api.example.com

# 生产环境预设地址
# UNI_APP_API_PRESET_PROD=http://api.example.com
