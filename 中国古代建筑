# 问答逻辑
def answer_question(question):
    # 简单的规则匹配
    question = question.lower()
    
    # 匹配建筑名称
    for _, row in df.iterrows():
        if row['name'] in question:
            return f"{row['name']}是{row['dynasty']}时期的{row['type']}，位于{row['province']}{row['city']}，建成于{row['year']}年。保护级别为{row['level']}。{row['intro']}"
    
    # 匹配建筑类型
    for building_type in df['type'].unique():
        if building_type in question:
            type_buildings = df[df['type'] == building_type]
            names = ', '.join(type_buildings['name'].tolist())
            return f"属于{building_type}类型的古代建筑有：{names}。"
    
    # 匹配朝代
    for dynasty in df['dynasty'].unique():
        if dynasty in question:
            dynasty_buildings = df[df['dynasty'] == dynasty]
            names = ', '.join(dynasty_buildings['name'].tolist())
            return f"{dynasty}时期的古代建筑有：{names}。"
    
    # 匹配保护级别
    if "保护级别" in question or "世界遗产" in question:
        world_heritage = df[df['level'] == "世界遗产"]
        names = ', '.join(world_heritage['name'].tolist())
        return f"被列为世界遗产的古代建筑有：{names}。"
    
    # 默认回答
    return "抱歉，我无法回答这个问题。您可以尝试询问关于具体建筑的信息，例如'故宫的介绍是什么？'"

