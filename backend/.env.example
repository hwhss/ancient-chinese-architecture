# PostgreSQL 数据库配置
# 复制此文件为 .env 并修改实际值

# 数据库连接 URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/ancient_architecture

# 数据库连接池配置
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# 数据源切换开关
# postgres - 使用 PostgreSQL 数据库（当前默认）
# json - 仅应急调试使用（FORCE_POSTGRES=true 时会被阻止）
DATA_SOURCE=postgres

# 强制 PostgreSQL 模式（向量检索链路建议始终开启）
FORCE_POSTGRES=true

# JSON 数据库目录（当 DATA_SOURCE=json 时生效）
# 默认读取 backend/data-jsondb（当前主数据集，26 条建筑）
# 若目录缺失会直接报错，避免静默回退到旧小数据集
DATA_JSON_DB_DIR=data-jsondb

# 仅应急使用：允许回退到 backend/data（旧小数据集）
ENABLE_LEGACY_JSON_FALLBACK=false

# seed 导入行为
# true  - 导入前清空目标表（推荐开发环境）
# false - 保留原数据并 upsert
SEED_TRUNCATE=true

# 仅 legacy seed 脚本使用的安全开关（默认禁用）
ALLOW_LEGACY_SEED=false

# 聊天检索参数
# 关键词匹配阈值（当前默认 20）
CHAT_KEYWORD_SCORE_THRESHOLD=20
CHAT_KEYWORD_STRONG_THRESHOLD=60
CHAT_KEYWORD_TOP_K=5

# 向量检索开关（默认关闭，避免未完成配置时影响主链路）
ENABLE_VECTOR_RETRIEVAL=false
CHAT_VECTOR_SIMILARITY_THRESHOLD=0.20
# 防误召回门槛：当关键词完全未命中时，向量相似度低于该值将直接回退AI
CHAT_VECTOR_MIN_DOMAIN_SIMILARITY=0.45
CHAT_VECTOR_TOP_K=5

# 混合打分（关键词 + 向量）
CHAT_HYBRID_SCORE_THRESHOLD=0.20
CHAT_HYBRID_KEYWORD_WEIGHT=0.45
CHAT_HYBRID_VECTOR_WEIGHT=0.55

# Embedding 配置（向量检索开启后必填）
# 当前预置 DashScope（阿里云）配置
# text-embedding-v4 实际维度为 1024
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your_dashscope_api_key_here
EMBEDDING_API_KEY=${DASHSCOPE_API_KEY}
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024

# Chat 大模型配置（用于兜底回答、问题纠错、知识答案润色）
LLM_PROVIDER=dashscope
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=${DASHSCOPE_API_KEY}
LLM_CHAT_MODEL=qwen-turbo

# Chat 体验增强开关
# true: 先做问题纠错后检索
# true: 知识库命中后用大模型做轻量润色
ENABLE_QUESTION_NORMALIZE=true
ENABLE_CHAT_REWRITE=true

# Chat 可观测字段开关（建议开发开，生产关）
CHAT_DEBUG_ENABLED=true

# 七牛云对象存储配置
# AccessKey / SecretKey：七牛云密钥
# Bucket：对象存储空间名
# Domain：可选。若不填则默认回退到 <bucket>.qiniudn.com
QINIU_ACCESS_KEY=your_qiniu_access_key
QINIU_SECRET_KEY=your_qiniu_secret_key
QINIU_BUCKET=your_bucket_name
QINIU_DOMAIN=your-bucket-domain.example.com

# true：使用 https 生成访问链接
QINIU_USE_HTTPS=true
# true：私有空间，后端会生成带过期时间的签名链接
QINIU_PRIVATE_BUCKET=true
# 签名链接默认有效期（秒）
QINIU_DOWNLOAD_EXPIRE_SECONDS=600

# 图片来源模式
# object - 使用对象存储（七牛）签名链接
# local  - 使用本地静态资源地址
IMAGE_SOURCE_MODE=object
# 当 IMAGE_SOURCE_MODE=local 时，图片 URL 基础地址
# 例如：http://localhost:9527/assets
# 说明：后端会按“建筑ID->相对路径映射”补全图片路径，再拼接到该 base URL
# 映射文件位置：backend/src/config/localImageMap.js
LOCAL_ASSET_BASE_URL=
# 可选：本地图片目录。配置后后端会自动把该目录挂载到 /assets
# 例如：D:/Gitproject/workspace/中国古建筑/picture
LOCAL_ASSET_DIR=

# 本地3D模型目录（可选）。配置后后端会自动挂载到 /models
# 例如：D:/Gitproject/workspace/中国古建筑/model
LOCAL_MODEL_DIR=
# 可选：本地3D模型访问基地址。不填时使用相对地址 /models/*
LOCAL_MODEL_BASE_URL=

# 其他配置
NODE_ENV=development
PORT=9527
