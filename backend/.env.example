# PostgreSQL 数据库配置
# 复制此文件为 .env 并修改实际值

# 数据库连接 URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/ancient_architecture

# 数据库连接池配置
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# 数据源切换开关
# json - 使用 JSON 文件（当前默认）
# postgres - 使用 PostgreSQL 数据库
DATA_SOURCE=json

# JSON 数据库目录（当 DATA_SOURCE=json 时生效）
# 默认会优先读取 backend/data-jsondb；未找到时回退 backend/data
DATA_JSON_DB_DIR=data-jsondb

# seed 导入行为
# true  - 导入前清空目标表（推荐开发环境）
# false - 保留原数据并 upsert
SEED_TRUNCATE=true

# 聊天检索参数
# 关键词匹配阈值（当前默认 20）
CHAT_KEYWORD_SCORE_THRESHOLD=20
CHAT_KEYWORD_STRONG_THRESHOLD=60
CHAT_KEYWORD_TOP_K=5

# 向量检索开关（默认关闭，避免未完成配置时影响主链路）
ENABLE_VECTOR_RETRIEVAL=false
CHAT_VECTOR_SIMILARITY_THRESHOLD=0.20
# 防误召回门槛：当关键词完全未命中时，向量相似度低于该值将直接回退AI
CHAT_VECTOR_MIN_DOMAIN_SIMILARITY=0.45
CHAT_VECTOR_TOP_K=5

# 混合打分（关键词 + 向量）
CHAT_HYBRID_SCORE_THRESHOLD=0.20
CHAT_HYBRID_KEYWORD_WEIGHT=0.45
CHAT_HYBRID_VECTOR_WEIGHT=0.55

# Embedding 配置（向量检索开启后必填）
# 当前预置 DashScope（阿里云）配置
# text-embedding-v4 实际维度为 1024
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your_dashscope_api_key_here
EMBEDDING_API_KEY=${DASHSCOPE_API_KEY}
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024

# Chat 大模型配置（用于兜底回答、问题纠错、知识答案润色）
LLM_PROVIDER=dashscope
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=${DASHSCOPE_API_KEY}
LLM_CHAT_MODEL=qwen-turbo

# Chat 体验增强开关
# true: 先做问题纠错后检索
# true: 知识库命中后用大模型做轻量润色
ENABLE_QUESTION_NORMALIZE=true
ENABLE_CHAT_REWRITE=true

# Chat 可观测字段开关（建议开发开，生产关）
CHAT_DEBUG_ENABLED=true

# 其他配置
NODE_ENV=development
PORT=9527
